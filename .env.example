# ─────────────────────────────────────────────────────────────────────────────
# Harvard Housing Commute Explorer — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
#
# 1. Copy this file:   cp .env.example .env
# 2. Get an API key:   https://developers.google.com/maps/get-started
# 3. Enable these APIs in your Google Cloud project:
#      • Maps JavaScript API
#      • Places API (New)   ← required for AutocompleteSuggestion + Place.fetchFields/searchByText/searchNearby
#      • Distance Matrix API
#      • Directions API
#      • Geocoding API
# 4. Paste your key below and restart the dev server (npm run dev)
#
# The app works without a key but shows a setup notice and cannot
# calculate commute times or display autocomplete suggestions.
# ─────────────────────────────────────────────────────────────────────────────

VITE_GOOGLE_MAPS_API_KEY=AIzaSyCZHSW6yDSF9hmUZJ9GNNZf9Uet_yYqhxg
